{
  "permissions": {
    "allow": [
      "Bash(php --version)",
      "Bash(composer --version)",
      "Bash(npm --version)",
      "Bash(psql --version)",
      "Bash(npm create:*)",
      "Bash(npm install:*)",
      "Bash(php artisan:*)",
      "Bash(composer dump-autoload:*)",
      "Bash(composer install:*)",
      "Bash(php -r ':*)",
      "Bash(npm run:*)",
      "Bash(npx vite:*)",
      "Bash(tasklist /fi \"PID eq 4876\")",
      "Bash(cmd /c \"taskkill /F /PID 4876\")",
      "Bash(powershell -Command \"Stop-Process -Id 4876 -Force\")",
      "Bash(netstat -ano)",
      "Bash(powershell -Command \"Get-Process -Id \\(Get-NetTCPConnection -LocalPort 8000\\).OwningProcess | Select-Object Id,ProcessName,Path\")"
    ]
  }
}
